{
  "name": "cropwatch-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd app && npm install && cd ../api && npm install",
    "app": "cd app && npm start",
    "api": "cd api && npm start",
    "dev": "npx concurrently \"npm run api\" \"npm run app\"",
    "tunnel:api": "cd api && npm run tunnel",
    "tunnel:app": "cd app && npm run tunnel",
    "setup:demo": "node scripts/sync-tunnels.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
